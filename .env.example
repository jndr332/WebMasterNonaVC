# Copia este archivo como .env y completa los valores

# Gmail (usa una App Password, NO tu contraseña normal)
# Para generar: Cuenta Google > Seguridad > Verificación en 2 pasos > Contraseñas de aplicaciones
GMAIL_USER=tucorreo@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Número de WhatsApp del organizador (solo dígitos, con código de país)
# Ejemplo Ecuador: 593987654321
WHATSAPP_NUMBER=593987654321

# Puerto del servidor
PORT=3000

# Contraseña para acceder al panel /admin
ADMIN_PASSWORD=admin2026
